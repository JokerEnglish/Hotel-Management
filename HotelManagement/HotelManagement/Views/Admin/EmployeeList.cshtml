@model IEnumerable<HotelManagement.Models.Nhanvien>
@{
    ViewData["Title"] = "Quản Lý Nhân Viên";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">👥 QUẢN LÝ NHÂN VIÊN</h2>
        <a href="#" class="btn btn-success fw-bold shadow-sm">+ Thêm Nhân Viên Mới</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark text-center">
                    <tr>
                        <th>Mã NV</th>
                        <th>Họ và Tên</th>
                        <th>Giới Tính</th>
                        <th>Ngày Sinh</th>
                        <th>Số Điện Thoại</th>
                        <th>Email</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody class="text-center align-middle">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-secondary">NV-@item.Manv</td>
                            <td class="fw-bold text-primary">@item.Hoten</td>
                            <td>
                                @if (item.Phai == "Nam")
                                {
                                    <span class="badge bg-info text-dark px-3 py-2">Nam 👨</span>
                                }
                                else if (item.Phai == "Nữ")
                                {
                                    <span class="badge bg-danger px-3 py-2">Nữ 👩</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary px-3 py-2">@item.Phai</span>
                                }
                            </td>
                            <td>@(item.Ngaysinh?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                            <td>@item.Sdt</td>
                            <td>@item.Email</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary fw-bold mx-1">Sửa</button>
                                <button class="btn btn-sm btn-outline-danger fw-bold mx-1">Xóa</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
