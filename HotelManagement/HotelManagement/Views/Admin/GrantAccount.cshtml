@model HotelManagement.Models.Taikhoan
@{
    ViewData["Title"] = "Cấp Tài Khoản";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow border-0 rounded-3 mb-4" role="alert">
                    🎉 <strong>Thành công!</strong> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-dark bg-gradient text-white text-center py-3 rounded-top-4">
                    <h3 class="fw-bold mb-0">🔑 CẤP TÀI KHOẢN</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="GrantAccount" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Chọn Nhân Viên</label>
                            <select asp-for="Manv" class="form-select rounded-3" required>
                                <option value="">-- Chọn nhân viên để cấp tài khoản --</option>
                                @if (ViewBag.Employees != null)
                                {
                                    foreach (var emp in ViewBag.Employees)
                                    {
                                        <option value="@emp.Manv">NV-@emp.Manv - @emp.Hoten (@emp.Email)</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="Manv" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Tentknv" class="form-label fw-bold text-secondary">Tên tài khoản (Email/Username)</label>
                            <input asp-for="Tentknv" class="form-control rounded-3" placeholder="Nhập tên đăng nhập..." required />
                            <span asp-validation-for="Tentknv" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Mktk" class="form-label fw-bold text-secondary">Mật khẩu tài khoản</label>
                            <input asp-for="Mktk" type="password" class="form-control rounded-3" placeholder="Nhập mật khẩu..." required />
                            <span asp-validation-for="Mktk" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Vaitro" class="form-label fw-bold text-secondary">Vai trò</label>
                            <select asp-for="Vaitro" class="form-select rounded-3" required>
                                <option value="NHANVIEN">NHANVIEN</option>
                                <option value="ADMIN">ADMIN</option>
                            </select>
                            <span asp-validation-for="Vaitro" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-controller="Admin" asp-action="EmployeeList" class="btn btn-outline-secondary px-4 fw-bold rounded-3">
                                ⬅ Danh Sách Nhân Viên
                            </a>
                            <button type="submit" class="btn btn-primary px-4 fw-bold rounded-3 shadow">
                                Tạo Tài Khoản
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
