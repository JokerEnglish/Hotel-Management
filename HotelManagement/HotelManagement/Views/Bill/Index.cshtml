@model IEnumerable<HotelManagement.Models.Hoadon>

@{
    ViewData["Title"] = "Hóa Đơn";
    Layout = "_Layout";
}

<style>
    .centered-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: vh;
    }

    .right-aligned {
        text-align: right;
    }

    .form-group-label {
        margin-bottom: 3px; /* Thêm khoảng cách giữa các nhóm label-input */
    }
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>

<h1 class="text-center mb-3">LỊCH SỬ HÓA ĐƠN</h1>
<div class="mb-3"></div>
@if (!User.IsInRole("Customer"))
{
    <div>
        <form asp-action="Test2">
            <button type="submit" class="btn btn-primary float-right">Lập Hóa Đơn</button>
        </form>
    </div>
}

<div class="mb-3"></div>
<table class="table table-striped table-bordered text-center">
    <thead class="thead-dark">
        <tr>
            <th>
                Tên Khách Hàng
            </th>
            <th>
                Tên Phòng
            </th>
            <th>
                Ngày Thanh Toán
            </th>
            <th>
                Tổng Tiền
            </th>
            <th>
                HT Thanh Toán
            </th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Tenkh)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Tenphong)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Ngaylaphd)
                </td>
                <td>
                    <span class="text-danger fw-bold">@item.Tongtien.ToString("N0") đ</span>
                </td>
                <td>
                    <span class="badge bg-secondary">@(item.HinhThucThanhToan ?? "N/A")</span>
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Mahd" class="btn btn-info btn-sm">Chi tiết</a>
                    @if (User.IsInRole("Customer") && item.HinhThucThanhToan == "Chuyển khoản")
                    {
                        <button type="button" class="btn btn-success btn-sm ms-1" data-bs-toggle="modal" data-bs-target="#paymentModal-@item.Mahd">
                            💳 Thanh toán
                        </button>

                        <!-- Modal Thanh Toán -->
                        <div class="modal fade" id="paymentModal-@item.Mahd" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content text-start">
                                    <div class="modal-header bg-success text-white">
                                        <h5 class="modal-title fw-bold">Thanh Toán Online Hóa Đơn #@item.Mahd</h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body text-center">
                                        <p class="mb-2">Quý khách vui lòng quét mã QR dưới đây bằng ứng dụng ngân hàng hoặc ví điện tử (Momo/ZaloPay).</p>
                                        <div class="p-3 border rounded bg-light d-inline-block mb-3 shadow-sm">
                                            <!-- Sử dụng ảnh mã QR sinh động -->
                                            <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=ChuyenKhoanHoaDon_@item.Mahd" alt="QR Code" class="img-fluid" />
                                        </div>
                                        <h4 class="text-danger fw-bold">Số tiền: @item.Tongtien.ToString("N0") đ</h4>
                                        <p class="text-muted small">Nội dung CK: <strong class="text-dark">THANHTOAN @item.Mahd PHONG @item.Tenphong</strong></p>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                                        <button type="button" class="btn btn-success fw-bold" onclick="alert('Đã gửi xác nhận thanh toán thành công!'); $('#paymentModal-@item.Mahd').modal('hide');">Đã Thanh Toán</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.js"></script>
<script>
    jQuery(document).ready(function ($) {
    var table = $('.table').DataTable({
    paging: false, // Disable paging
    searching: false // Disable searching
    });

    // Apply sorting to all columns by default (you can specify columns for sorting if needed)
    table.order([2, 'desc']).draw();
    });
</script>
