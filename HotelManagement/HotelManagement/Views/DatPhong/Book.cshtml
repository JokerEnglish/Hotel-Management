@{
    ViewData["Title"] = "Đặt Phòng";
    var phong = ViewBag.Phong as HotelManagement.Models.Phong;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h3 class="mb-0 fw-bold">🏨 ĐẶT PHÒNG</h3>
                </div>
                <div class="card-body p-4">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }

                    <h5 class="text-info fw-bold mb-3">Phòng: @phong.Tenphong</h5>
                    <p class="text-muted">Giá tạm tính: <strong class="text-danger">500,000 VNĐ / Ngày</strong></p>
                    
                    <form asp-action="Book" method="post">
                        <input type="hidden" name="Map" value="@phong.Map" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ngày Nhận Phòng (Dự kiến):</label>
                            <input type="date" name="NgayNhan" class="form-control" required min="@DateTime.Now.ToString("yyyy-MM-dd")" id="ngayNhan" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ngày Trả Phòng (Dự kiến):</label>
                            <input type="date" name="NgayTra" class="form-control" required min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" id="ngayTra" />
                        </div>

                        <div class="alert alert-warning mb-4">
                            <i class="bi bi-info-circle-fill"></i> 
                            <strong>Hình thức thanh toán:</strong> Thanh toán tại quầy khi nhận phòng. Tuy nhiên, sau khi bạn đặt, thông tin sẽ được gửi đến Nhân viên duyệt. Hãy chú ý điện thoại!
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg fw-bold">✅ Xác nhận Đặt Phòng</button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Trở về</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tự động kiểm tra ngày trả lớn hơn ngày nhận
        document.getElementById("ngayNhan").addEventListener("change", function() {
            var ngayNhan = new Date(this.value);
            ngayNhan.setDate(ngayNhan.getDate() + 1);
            var ngayTraInput = document.getElementById("ngayTra");
            var minNgayTra = ngayNhan.toISOString().split('T')[0];
            ngayTraInput.setAttribute("min", minNgayTra);
            if (ngayTraInput.value < minNgayTra) {
                ngayTraInput.value = minNgayTra;
            }
        });
    </script>
}
