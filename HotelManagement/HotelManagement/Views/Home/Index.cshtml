@model HotelManagement.ViewModels.PaginatedList<HotelManagement.Models.Phong>
@{
    ViewData["Title"] = "Trang Chủ - Danh Sách Phòng";
}

<style>
    .home-hero {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        padding: 3rem 2rem;
        border-radius: 16px;
        margin-bottom: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        position: relative;
        overflow: hidden;
    }
    .home-hero::after {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 300px;
        height: 300px;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
        filter: blur(40px);
    }
    .search-box {
        background: white;
        padding: 8px;
        border-radius: 50px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        max-width: 600px;
        margin: 0 auto;
    }
    .search-box input {
        border: none;
        box-shadow: none;
        padding-left: 20px;
        border-radius: 50px;
    }
    .search-box input:focus {
        box-shadow: none;
        outline: none;
    }
    .search-box button {
        border-radius: 50px;
        padding: 10px 25px;
        font-weight: 600;
    }
    .room-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }
    @@media (max-width: 1200px) { .room-grid { grid-template-columns: repeat(4, 1fr); } }
    @@media (max-width: 992px) { .room-grid { grid-template-columns: repeat(3, 1fr); } }
    @@media (max-width: 768px) { .room-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 480px) { .room-grid { grid-template-columns: 1fr; } }
    
    .room-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        border: 1px solid #f0f0f0;
        position: relative;
        overflow: hidden;
    }
    .room-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 25px rgba(0,0,0,0.08);
        border-color: #e0e0e0;
    }
    .room-image-container {
        height: 65px;
        width: 65px;
        margin: 0 auto 15px auto;
        position: relative;
        border-radius: 50%;
        background: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }
    .room-hover-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        position: absolute;
        top: 0;
        left: 0;
        opacity: 0;
        transition: opacity 0.4s ease;
    }
    .room-icon {
        font-size: 2.2rem;
        position: absolute;
        transition: opacity 0.3s ease;
    }
    .room-card:hover .room-image-container {
        width: 100%;
        height: 160px;
        border-radius: 12px;
    }
    .room-card:hover .room-hover-img {
        opacity: 1;
    }
    .room-card:hover .room-icon {
        opacity: 0;
    }
    .room-title {
        font-weight: 700;
        font-size: 1.25rem;
        color: #2c3e50;
        margin-bottom: 5px;
    }
    .room-type {
        color: #7f8c8d;
        font-size: 0.9rem;
        margin-bottom: 15px;
    }
    .room-price {
        font-weight: 700;
        color: #e67e22;
        font-size: 1.1rem;
        background: rgba(230, 126, 34, 0.1);
        padding: 5px 10px;
        border-radius: 8px;
        display: inline-block;
        margin-bottom: 15px;
    }
    .room-status {
        font-weight: 600;
        padding: 6px 15px;
        border-radius: 50px;
        font-size: 0.85rem;
        display: inline-block;
    }
    .status-trong { background: #e8f5e9; color: #2e7d32; }
    .status-dangthue { background: #ffebee; color: #c62828; }
    .status-baotri { background: #fff3e0; color: #ef6c00; }
    
    .pagination-container {
        display: flex;
        justify-content: center;
        margin-top: 2rem;
    }
    .page-link {
        border-radius: 8px;
        margin: 0 5px;
        color: #2a5298;
        font-weight: 600;
        border: 1px solid #e2e8f0;
    }
    .page-item.active .page-link {
        background-color: #2a5298;
        border-color: #2a5298;
        color: white;
    }
</style>

<div class="home-hero text-center animate-in">
    <h1 class="fw-bold mb-3">Hệ Thống Hiện Phòng</h1>
    <p class="mb-4 text-white-50">Lựa chọn phòng phù hợp cho khách hàng của bạn nhanh chóng và dễ dàng</p>
    
    <form asp-action="Index" method="get">
        <div class="search-box d-flex">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Nhập tên phòng cần tìm..." />
            <button type="submit" class="btn btn-primary px-4">🔍 Tìm kiếm</button>
        </div>
    </form>
</div>

<div class="container-fluid px-0 animate-in" style="animation-delay: 0.1s;">
    @if (!Model.Items.Any())
    {
        <div class="text-center p-5 bg-white rounded-4 shadow-sm border">
            <h3 class="text-muted">📭 Không tìm thấy phòng nào</h3>
            <p>Vui lòng thử lại với từ khóa khác.</p>
        </div>
    }
    else
    {
        <div class="room-grid">
            @foreach (var room in Model.Items)
            {
                <!-- Vùng bọc Card để làm sự kiện Click mở Modal -->
                <div class="room-card" data-bs-toggle="modal" data-bs-target="#modalRoom-@room.Map" style="cursor: pointer;" title="Nhấn để xem chi tiết">
                    @{
                        string imgUrl1 = "https://images.pexels.com/photos/164595/pexels-photo-164595.jpeg?auto=compress&cs=tinysrgb&w=600";
                        string imgUrl2 = "https://images.pexels.com/photos/271618/pexels-photo-271618.jpeg?auto=compress&cs=tinysrgb&w=600";
                        string imgUrl3 = "https://images.pexels.com/photos/271624/pexels-photo-271624.jpeg?auto=compress&cs=tinysrgb&w=600";
                        if (room.MaloaiphongNavigation != null) {
                            string loai = room.MaloaiphongNavigation.Tenloai.ToLower();
                            if (loai.Contains("vip")) {
                                imgUrl1 = "https://images.pexels.com/photos/271618/pexels-photo-271618.jpeg?auto=compress&cs=tinysrgb&w=600";
                                imgUrl2 = "https://images.pexels.com/photos/1454806/pexels-photo-1454806.jpeg?auto=compress&cs=tinysrgb&w=600";
                                imgUrl3 = "https://images.pexels.com/photos/6480198/pexels-photo-6480198.jpeg?auto=compress&cs=tinysrgb&w=600";
                            } else if (loai.Contains("đơn")) {
                                imgUrl1 = "https://images.pexels.com/photos/271624/pexels-photo-271624.jpeg?auto=compress&cs=tinysrgb&w=600";
                                imgUrl2 = "https://images.pexels.com/photos/1743227/pexels-photo-1743227.jpeg?auto=compress&cs=tinysrgb&w=600";
                                imgUrl3 = "https://images.pexels.com/photos/271619/pexels-photo-271619.jpeg?auto=compress&cs=tinysrgb&w=600";
                            } else if (loai.Contains("đôi")) {
                                imgUrl1 = "https://images.pexels.com/photos/164595/pexels-photo-164595.jpeg?auto=compress&cs=tinysrgb&w=600";
                                imgUrl2 = "https://images.pexels.com/photos/1001965/pexels-photo-1001965.jpeg?auto=compress&cs=tinysrgb&w=600";
                                imgUrl3 = "https://images.pexels.com/photos/3201758/pexels-photo-3201758.jpeg?auto=compress&cs=tinysrgb&w=600";
                            }
                        }
                    }
                    <div class="room-image-container">
                        <img src="@imgUrl1" class="room-hover-img" alt="Room Decor" />
                        <div class="room-icon">🚪</div>
                    </div>
                    <div class="room-title">@room.Tenphong</div>
                    <div class="room-type mb-3">
                        @(room.MaloaiphongNavigation != null ? room.MaloaiphongNavigation.Tenloai : "Phòng Thường")
                    </div>
                    
                    <div>
                        @if (room.Tinhtrang == 1)
                        {
                            <span class="room-status status-trong mb-2">✅ Trống</span>
                        }
                        else if (room.Tinhtrang == 2)
                        {
                            <span class="room-status status-dangthue">❌ Đang Thuê</span>
                        }
                        else
                        {
                            <span class="room-status status-baotri">⚠️ Bảo Trì</span>
                        }
                    </div>
                </div>


            }
        </div>

        <!-- Phân trang -->
        <div class="pagination-container">
            <ul class="pagination">
                <!-- Nút Trước -->
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-pageNumber="@(Model.PageIndex - 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]">
                        « Trước
                    </a>
                </li>
                
                <!-- Hiển thị số trang -->
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-pageNumber="@i"
                           asp-route-searchString="@ViewData["CurrentFilter"]">@i</a>
                    </li>
                }

                <!-- Nút Tiếp -->
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-pageNumber="@(Model.PageIndex + 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]">
                        Tiếp »
                    </a>
                </li>
            </ul>
        </div>
    }
</div>

<!-- Render Modals ở ngoài container có animation để không bị lỗi position: fixed -->
@if (Model.Items.Any())
{
    @foreach (var room in Model.Items)
    {
        string imgUrl1 = "https://images.pexels.com/photos/164595/pexels-photo-164595.jpeg?auto=compress&cs=tinysrgb&w=600";
        string imgUrl2 = "https://images.pexels.com/photos/271618/pexels-photo-271618.jpeg?auto=compress&cs=tinysrgb&w=600";
        string imgUrl3 = "https://images.pexels.com/photos/271624/pexels-photo-271624.jpeg?auto=compress&cs=tinysrgb&w=600";
        if (room.MaloaiphongNavigation != null) {
            string loai = room.MaloaiphongNavigation.Tenloai.ToLower();
            if (loai.Contains("vip")) {
                imgUrl1 = "https://images.pexels.com/photos/271618/pexels-photo-271618.jpeg?auto=compress&cs=tinysrgb&w=600";
                imgUrl2 = "https://images.pexels.com/photos/1454806/pexels-photo-1454806.jpeg?auto=compress&cs=tinysrgb&w=600";
                imgUrl3 = "https://images.pexels.com/photos/6480198/pexels-photo-6480198.jpeg?auto=compress&cs=tinysrgb&w=600";
            } else if (loai.Contains("đơn")) {
                imgUrl1 = "https://images.pexels.com/photos/271624/pexels-photo-271624.jpeg?auto=compress&cs=tinysrgb&w=600";
                imgUrl2 = "https://images.pexels.com/photos/1743227/pexels-photo-1743227.jpeg?auto=compress&cs=tinysrgb&w=600";
                imgUrl3 = "https://images.pexels.com/photos/271619/pexels-photo-271619.jpeg?auto=compress&cs=tinysrgb&w=600";
            } else if (loai.Contains("đôi")) {
                imgUrl1 = "https://images.pexels.com/photos/164595/pexels-photo-164595.jpeg?auto=compress&cs=tinysrgb&w=600";
                imgUrl2 = "https://images.pexels.com/photos/1001965/pexels-photo-1001965.jpeg?auto=compress&cs=tinysrgb&w=600";
                imgUrl3 = "https://images.pexels.com/photos/3201758/pexels-photo-3201758.jpeg?auto=compress&cs=tinysrgb&w=600";
            }
        }

        <div class="modal fade" id="modalRoom-@room.Map" tabindex="-1" aria-labelledby="modalRoomLabel-@room.Map" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title fw-bold" id="modalRoomLabel-@room.Map">🏨 Chi tiết phòng: @room.Tenphong</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4">
                        <div class="row">
                            <div class="col-md-7 mb-3 mb-md-0">
                                <div id="carouselRoom-@room.Map" class="carousel slide shadow-sm rounded overflow-hidden" data-bs-ride="carousel">
                                    <div class="carousel-inner">
                                        <div class="carousel-item active">
                                            <img src="@imgUrl1" class="d-block w-100" style="height:300px; object-fit:cover;" alt="Góc 1">
                                        </div>
                                        <div class="carousel-item">
                                            <img src="@imgUrl2" class="d-block w-100" style="height:300px; object-fit:cover;" alt="Góc 2">
                                        </div>
                                        <div class="carousel-item">
                                            <img src="@imgUrl3" class="d-block w-100" style="height:300px; object-fit:cover;" alt="Góc 3">
                                        </div>
                                    </div>
                                    <button class="carousel-control-prev" type="button" data-bs-target="#carouselRoom-@room.Map" data-bs-slide="prev">
                                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                    </button>
                                    <button class="carousel-control-next" type="button" data-bs-target="#carouselRoom-@room.Map" data-bs-slide="next">
                                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                    </button>
                                </div>
                            </div>
                            <div class="col-md-5">
                                <h4 class="text-primary fw-bold mb-3 border-bottom pb-2">Thông tin phòng</h4>
                                <p class="mb-2"><i class="bi bi-tag-fill text-warning me-2"></i> <strong>Loại phòng:</strong> @(room.MaloaiphongNavigation != null ? room.MaloaiphongNavigation.Tenloai : "Phòng Thường")</p>
                                <p class="mb-2"><i class="bi bi-people-fill text-info me-2"></i> <strong>Số người tối đa:</strong> @room.Soluongkhachtoida người</p>
                                <p class="mb-2"><i class="bi bi-cash-coin text-success me-2"></i> <strong>Giá phòng:</strong> <span class="text-danger fw-bold fs-5">@(room.MaloaiphongNavigation != null ? room.MaloaiphongNavigation.Dongia.ToString("N0") + " đ/ngày" : "Đang cập nhật")</span></p>
                                <p class="mb-3"><i class="bi bi-info-circle-fill text-secondary me-2"></i> <strong>Tình trạng:</strong> 
                                    @if (room.Tinhtrang == 1) { <span class="badge bg-success fs-6">Trống</span> }
                                    else if (room.Tinhtrang == 2) { <span class="badge bg-danger fs-6">Đang Thuê</span> }
                                    else { <span class="badge bg-warning text-dark fs-6">Bảo Trì</span> }
                                </p>
                                <div class="p-3 bg-light rounded text-muted fs-6">
                                    <i class="bi bi-star-fill text-warning"></i> <strong>Mô tả:</strong> @(string.IsNullOrEmpty(room.Ghichu) ? "Phòng có đầy đủ tiện nghi, wifi miễn phí, tivi, máy lạnh và có cửa sổ view thoáng mát." : room.Ghichu)
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">Đóng</button>
                        @if (room.Tinhtrang == 1)
                        {
                            @if (User.IsInRole("ADMIN") || User.IsInRole("STAFF") || User.IsInRole("NHANVIEN"))
                            {
                                <a asp-controller="Rent" asp-action="Create" asp-route-roomName="@room.Tenphong" class="btn btn-primary fw-bold px-4 shadow-sm">
                                    📝 Lập Phiếu Thuê
                                </a>
                            }
                            else
                            {
                                <a asp-controller="DatPhong" asp-action="Book" asp-route-roomId="@room.Map" class="btn btn-success fw-bold px-4 shadow-sm">
                                    🛒 Đặt Phòng
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var elements = document.querySelectorAll('.animate-in');
        elements.forEach((el, index) => {
            el.style.opacity = '0';
            el.style.transform = 'translateY(20px)';
            el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
            setTimeout(() => {
                el.style.opacity = '1';
                el.style.transform = 'translateY(0)';
            }, 100 * index);
        });
    });
</script>
