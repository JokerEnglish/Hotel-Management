@model HotelManagement.Models.Loaikhach
@{
    ViewData["Title"] = "Thêm Loại Khách";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0 fw-bold">➕ Thêm Loại Khách Mới</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-4">
                    <label asp-for="Tenloaikhach" class="form-label fw-bold">
                        Tên Loại Khách <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Tenloaikhach" class="form-control form-control-lg"
                           placeholder="VD: Trong Nước, Nước Ngoài..." />
                    <span asp-validation-for="Tenloaikhach" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success fw-bold px-4">💾 Lưu</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>
