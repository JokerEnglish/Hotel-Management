@model IEnumerable<HotelManagement.Models.Loaikhach>
@{
    ViewData["Title"] = "Quản Lý Loại Khách";
}

<div class="container mt-4">
    <h2 class="text-primary fw-bold mb-4">👥 QUẢN LÝ LOẠI KHÁCH</h2>

    <!-- Thanh tìm kiếm và nút thêm -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <form asp-action="Index" method="get" class="w-50 m-0">
            <div class="input-group">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                       class="form-control" placeholder="Nhập tên loại khách cần tìm..." />
                <button type="submit" class="btn btn-primary fw-bold">🔍 Tìm Kiếm</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Xóa</a>
            </div>
        </form>
        <a asp-action="Create" class="btn btn-success fw-bold shadow-sm">+ Thêm Loại Khách Mới</a>
    </div>

    <!-- Bảng dữ liệu -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover table-bordered mb-0">
                <thead class="table-dark text-center">
                    <tr>
                        <th style="width: 150px;">Mã Loại Khách</th>
                        <th>Tên Loại Khách</th>
                        <th style="width: 200px;">Hành Động</th>
                    </tr>
                </thead>
                <tbody class="text-center align-middle">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-secondary">@item.Maloaikhach</td>
                                <td class="fw-bold text-primary">@item.Tenloaikhach</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Maloaikhach"
                                       class="btn btn-sm btn-outline-warning fw-bold mx-1">✏️ Sửa</a>
                                    <a asp-action="Delete" asp-route-id="@item.Maloaikhach"
                                       class="btn btn-sm btn-outline-danger fw-bold mx-1"
                                       onclick="return confirm('Bạn có chắc muốn xóa loại khách này?')">🗑️ Xóa</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-muted py-4">Không có dữ liệu loại khách.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
