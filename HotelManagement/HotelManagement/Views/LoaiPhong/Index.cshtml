@model IEnumerable<HotelManagement.Models.Loaiphong>
@{
    ViewData["Title"] = "Quản Lý Loại Phòng";
}

<div class="container mt-4">
    <h2 class="text-primary fw-bold mb-4">QUẢN LÝ LOẠI PHÒNG</h2>
    
    <!-- Khu vực Thanh Tìm Kiếm và Nút Thêm -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        
        <!-- Thanh Tìm Kiếm (Bên trái) -->
        <form asp-action="Index" method="get" class="w-50 m-0">
            <div class="input-group">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Nhập tên loại phòng cần tìm..." />
                <button type="submit" class="btn btn-primary fw-bold">🔍 Tìm Kiếm</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Xóa</a>
            </div>
        </form>

        <!-- Nút Thêm Loại Phòng (Bên phải) -->
        <a asp-action="Create" class="btn btn-success fw-bold shadow-sm">+ Thêm Loại Phòng Mới</a>
        
    </div>

    <table class="table table-bordered table-hover shadow-sm bg-white">
        <thead class="table-dark text-center">
            <tr>
                <th>Mã Loại Phòng</th>
                <th>Tên Loại Phòng</th>
                <th>Đơn Giá (VNĐ)</th>
                <th>Hành Động</th>
            </tr>
        </thead>
        <tbody class="text-center align-middle">
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold">@item.Maloaiphong</td>
                    <td class="text-primary fw-bold">@item.Tenloai</td>
                    <td class="text-danger fw-bold">@item.Dongia.ToString("N0")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Maloaiphong" class="btn btn-sm btn-outline-primary fw-bold mx-1">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.Maloaiphong" class="btn btn-sm btn-outline-danger fw-bold mx-1" onclick="return confirm('Cảnh báo: Nếu loại phòng này đang được gán cho các phòng có sẵn, việc xóa sẽ gây lỗi. Bạn có chắc chắn muốn xóa?');">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
