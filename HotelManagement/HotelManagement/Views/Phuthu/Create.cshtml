@model HotelManagement.Models.Phuthu
@{
    ViewData["Title"] = "Thêm Loại Phụ Thu";
}

<div class="container mt-4" style="max-width: 500px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0 fw-bold">➕ Thêm Loại Phụ Thu</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label asp-for="Giatriphuthu" class="form-label fw-bold">
                        Giá Trị Phụ Thu (%) <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <input asp-for="Giatriphuthu" type="number" step="0.01" min="0" max="100"
                               class="form-control form-control-lg" placeholder="VD: 25" />
                        <span class="input-group-text fw-bold">%</span>
                    </div>
                    <span asp-validation-for="Giatriphuthu" class="text-danger small"></span>
                    <div class="form-text">Nhập tỷ lệ phần trăm phụ thu cho mỗi khách vượt quá sức chứa.</div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success fw-bold px-4">💾 Lưu</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>
