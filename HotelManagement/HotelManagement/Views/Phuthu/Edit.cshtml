@model HotelManagement.Models.Phuthu
@{
    ViewData["Title"] = "Sửa Loại Phụ Thu";
}

<div class="container mt-4" style="max-width: 500px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0 fw-bold">✏️ Sửa Loại Phụ Thu</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Idphuthu" />

                <div class="mb-4">
                    <label asp-for="Giatriphuthu" class="form-label fw-bold">
                        Giá Trị Phụ Thu (%) <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <input asp-for="Giatriphuthu" type="number" step="0.01" min="0" max="100"
                               class="form-control form-control-lg" />
                        <span class="input-group-text fw-bold">%</span>
                    </div>
                    <span asp-validation-for="Giatriphuthu" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold px-4">💾 Lưu Thay Đổi</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>
