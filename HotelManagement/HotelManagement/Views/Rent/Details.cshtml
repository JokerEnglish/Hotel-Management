@model HotelManagement.Models.Phieuthue
@{
    ViewData["Title"] = "Chi Tiết Phiếu Thuê";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0 fw-bold text-center">📄 CHI TIẾT PHIẾU THUÊ</h4>
        </div>
        <div class="card-body p-4">
            
            <div class="row mb-3 border-bottom pb-2">
                <div class="col-sm-4 fw-bold text-muted">Mã Phiếu Thuê:</div>
                <div class="col-sm-8 fw-bold text-primary fs-5">PT-@Model.Mapt</div>
            </div>

            <div class="row mb-3 border-bottom pb-2">
                <div class="col-sm-4 fw-bold text-muted">Ngày Lập:</div>
                <div class="col-sm-8 fw-bold">@Model.Ngaylappt.ToString("dd/MM/yyyy")</div>
            </div>

            <div class="row mb-3 border-bottom pb-2">
                <div class="col-sm-4 fw-bold text-muted">Tên Khách Hàng:</div>
                <div class="col-sm-8 fw-bold text-success">@Model.MakhNavigation?.Tenkh</div>
            </div>

            <div class="row mb-3 border-bottom pb-2">
                <div class="col-sm-4 fw-bold text-muted">Số CCCD:</div>
                <div class="col-sm-8">@Model.Cccd</div>
            </div>

            <div class="row mb-3 pb-2">
                <div class="col-sm-4 fw-bold text-muted">Phòng Đang Thuê:</div>
                <div class="col-sm-8">
                    <span class="badge bg-primary px-3 py-2 fs-6">@Model.MapNavigation?.Tenphong</span>
                </div>
            </div>

            <div class="d-flex justify-content-center gap-3 mt-4">
                <a asp-action="Edit" asp-route-id="@Model.Mapt" class="btn btn-warning fw-bold px-4">✏️ Sửa</a>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">🔙 Quay Lại Danh Sách</a>
            </div>

        </div>
    </div>
</div>
