@model HotelManagement.Models.Phieuthue
@{
    ViewData["Title"] = "Sửa Phiếu Thuê";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0 fw-bold text-center">✏️ SỬA PHIẾU THUÊ</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Mapt" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Ngày Lập Phiếu Thuê <span class="text-danger">*</span></label>
                    <input type="date" name="Ngaylappt" class="form-control"
                           value="@Model.Ngaylappt.ToString("yyyy-MM-dd")" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Căn Cước Công Dân (CCCD) <span class="text-danger">*</span></label>
                    <input type="text" name="Cccd" class="form-control" value="@Model.Cccd" required />
                    @Html.ValidationMessage("Cccd", "", new { @class = "text-danger mt-1 small fw-bold" })
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Tên Phòng <span class="text-danger">*</span></label>
                    <select name="TenPhong" class="form-select" required>
                        @foreach (var phong in ViewBag.DanhSachPhong as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)
                        {
                            if (phong.Value == ViewBag.CurrentTenPhong)
                            {
                                <option value="@phong.Value" selected>@phong.Text</option>
                            }
                            else
                            {
                                <option value="@phong.Value">@phong.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold px-4">💾 Lưu Thay Đổi</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>
